function beginClock(){
  updateTimerDisplay();
  setInterval(()=>{
    if(isPaused)return;
    state.market.countdown--;
    if(state.market.countdown<=0){processMarketTick();state.market.countdown=state.market.maxCountdown||5;}
    updateTimerDisplay();
  },1000);
}
function togglePause(){
  isPaused=!isPaused;
  const btn=document.getElementById('pause-btn');
  if(!btn)return;
  btn.innerText=isPaused?'▶':'⏸';
  btn.style.color=isPaused?'var(--green)':'var(--accent)';
  btn.style.borderColor=isPaused?'var(--green)':'var(--accent)';
}
function autoPauseOnTradeInput(){
  const c=document.getElementById('auto-pause-checkbox');
  if(c&&c.checked&&!isPaused)togglePause();
}
function updateTimerDisplay(){
  const m=Math.floor((state.market.countdown||0)/60);
  const s=(state.market.countdown||0)%60;
  const el=document.getElementById('timer-val');
  if(el)el.innerText=`${String(m).padStart(2,'0')}:${String(s).padStart(2,'0')}`;
}
function applyDMTimerModifications(){
  const c=parseInt(document.getElementById('dm-timer-current').value);
  const d=parseInt(document.getElementById('dm-timer-max').value);
  if(!isNaN(c)&&c>=0)state.market.countdown=c;
  if(!isNaN(d)&&d>=2)state.market.maxCountdown=d;
  updateTimerDisplay();
  alert("Clock synchronized.");
}

