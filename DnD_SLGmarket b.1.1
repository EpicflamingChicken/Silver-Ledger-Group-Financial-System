<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Silver Ledger Group Market Terminal</title>
<style>
:root {
  --bg: #0f0f11; --panel-bg: #16161a; --border: #26262b;
  --accent: #d4af37; --text: #e4e4e7; --text-muted: #71717a;
  --green: #4ade80; --red: #f87171; --dm-accent: #ea580c;
  --blue: #60a5fa; --purple: #a78bfa; --yellow: #fbbf24;
}
* { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
body { background: var(--bg); color: var(--text); min-height: 100vh; }

/* ── NAV ── */
.top-nav { background: var(--panel-bg); border-bottom: 1px solid var(--border); padding: 0 24px; display: flex; align-items: center; gap: 0; }
.nav-brand { color: var(--accent); font-weight: 700; font-size: 1rem; letter-spacing: -0.02em; padding: 16px 24px 16px 0; border-right: 1px solid var(--border); margin-right: 8px; white-space: nowrap; }
.nav-tab { padding: 16px 18px; font-size: 0.85rem; color: var(--text-muted); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; white-space: nowrap; }
.nav-tab:hover { color: var(--text); }
.nav-tab.active { color: var(--accent); border-bottom-color: var(--accent); }
.nav-right { margin-left: auto; display: flex; gap: 8px; align-items: center; padding-left: 16px; }

/* ── LAYOUT ── */
.page { display: none; padding: 24px; flex-direction: column; gap: 20px; }
.page.active { display: flex; }
.panel { background: var(--panel-bg); border: 1px solid var(--border); border-radius: 6px; padding: 20px; }
.panel-sm { background: var(--panel-bg); border: 1px solid var(--border); border-radius: 6px; padding: 14px 16px; }
.grid-2 { display: grid; grid-template-columns: 1fr 340px; gap: 20px; }
.grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
.grid-5 { display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; }
@media (max-width: 1100px) { .grid-5 { grid-template-columns: repeat(3,1fr); } .grid-4 { grid-template-columns: repeat(2,1fr); } }
@media (max-width: 900px) { .grid-2 { grid-template-columns: 1fr; } .grid-3 { grid-template-columns: 1fr; } }
.flex-between { display: flex; justify-content: space-between; align-items: center; }
.flex-gap { display: flex; gap: 8px; align-items: center; }
.flex-gap > * { min-width: 0; } /* allow flex children (inputs/selects/buttons) to shrink instead of overflowing */
.input-group { display: flex; align-items: stretch; }
.input-group input { flex: 1 1 auto; min-width: 0; border-radius: 4px 0 0 4px; border-right: none; }
.input-group select { flex: 0 1 auto; min-width: 0; border-radius: 0 4px 4px 0; }
.input-group input:focus, .input-group select:focus { border-color: var(--accent); z-index: 1; }

/* ── TYPE ── */
h2 { font-size: 0.75rem; font-weight: 500; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 14px; }
h3 { font-size: 0.95rem; font-weight: 600; margin-bottom: 10px; }
.label { font-size: 0.72rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; }
.up { color: var(--green); } .down { color: var(--red); } .muted { color: var(--text-muted); }

/* ── BUTTONS ── */
button { background: transparent; color: var(--accent); border: 1px solid var(--accent); padding: 6px 12px; font-size: 0.83rem; border-radius: 4px; cursor: pointer; transition: all 0.15s; }
button:hover { background: rgba(212,175,55,0.1); }
button.btn-primary { background: var(--accent); color: var(--bg); font-weight: 600; border-color: var(--accent); }
button.btn-primary:hover { background: #e8c84a; }
button.btn-ghost { color: var(--text); border-color: var(--border); }
button.btn-ghost:hover { background: rgba(255,255,255,0.04); border-color: var(--text-muted); }
button.btn-danger { color: var(--red); border-color: var(--red); }
button.btn-danger:hover { background: rgba(248,113,113,0.1); }
button.btn-dm { color: var(--dm-accent); border-color: var(--dm-accent); }
button.btn-dm:hover { background: rgba(234,88,12,0.1); }
input, select { background: var(--bg); border: 1px solid var(--border); color: var(--text); padding: 7px 10px; border-radius: 4px; font-size: 0.87rem; outline: none; }
input:focus, select:focus { border-color: var(--accent); }
.file-input-wrapper { position: relative; overflow: hidden; display: inline-block; }
.file-input-wrapper input[type=file] { position: absolute; left: 0; top: 0; opacity: 0; font-size: 100px; cursor: pointer; width: 100%; height: 100%; }

/* ── TABLE ── */
table { width: 100%; border-collapse: collapse; font-size: 0.88rem; }
th { text-align: left; padding: 10px 8px; color: var(--text-muted); font-weight: 400; border-bottom: 1px solid var(--border); font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; }
td { padding: 11px 8px; border-bottom: 1px solid rgba(38,38,43,0.7); }
tr:last-child td { border-bottom: none; }
th.sortable { cursor: pointer; user-select: none; }
th.sortable:hover { color: var(--text); }

/* ── TICKER ── */
.ticker-wrap { background: var(--panel-bg); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); overflow: hidden; padding: 10px 0; }
.ticker { display: flex; white-space: nowrap; animation: moveTicker 240s linear infinite; width: max-content; }
.ticker:hover { animation-play-state: paused; }
.ticker-item { display: inline-flex; align-items: center; gap: 6px; margin-right: 40px; font-size: 0.82rem; letter-spacing: 0.04em; }
@keyframes moveTicker { 0% { transform: translate3d(0,0,0); } 100% { transform: translate3d(-50%,0,0); } }

/* ── METRIC CARDS ── */
.metric-card { padding: 14px 16px; }
.metric-val { font-size: 1.5rem; font-weight: 400; line-height: 1; margin: 4px 0; }
.metric-sub { font-size: 0.78rem; color: var(--text-muted); }

/* ── GAUGE ── */
.gauge-bar { height: 3px; background: var(--border); border-radius: 2px; margin-top: 6px; }
.gauge-fill { height: 100%; border-radius: 2px; transition: width 0.7s ease; }

/* ── BADGES ── */
.badge { display: inline-block; font-size: 0.65rem; padding: 2px 6px; border-radius: 3px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em; }
.badge-startup  { background: rgba(96,165,250,0.12); color: var(--blue); border: 1px solid rgba(96,165,250,0.25); }
.badge-growth   { background: rgba(74,222,128,0.12); color: var(--green); border: 1px solid rgba(74,222,128,0.25); }
.badge-mature   { background: rgba(212,175,55,0.10); color: var(--accent); border: 1px solid rgba(212,175,55,0.2); }
.badge-declining{ background: rgba(248,113,113,0.12); color: var(--red); border: 1px solid rgba(248,113,113,0.25); }
.badge-bankrupt { background: rgba(248,113,113,0.22); color: var(--red); border: 1px solid var(--red); }
.badge-sector   { background: rgba(255,255,255,0.05); color: var(--text-muted); border: 1px solid var(--border); }
.badge-mood-bullish  { color: var(--green); } .badge-mood-neutral { color: var(--text-muted); } .badge-mood-bearish { color: var(--red); }

/* ── COMPANY DETAIL INLINE ROW ── */
.detail-row { background: #0c0c10; }
.detail-row td { padding: 0; }
.detail-inner { padding: 16px 20px 18px; }
.company-stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin: 12px 0; }
.company-stat { background: var(--bg); border: 1px solid var(--border); border-radius: 4px; padding: 10px 12px; }
.company-stat .s-label { font-size: 0.68rem; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.04em; margin-bottom: 3px; }
.company-stat .s-val { font-size: 1rem; font-weight: 500; }

/* ── NEWS FEED ── */
.news-item { padding: 10px 0; border-bottom: 1px solid var(--border); }
.news-item:last-child { border-bottom: none; }
.news-source { font-size: 0.7rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px; }
.news-headline { font-size: 0.88rem; color: var(--text); line-height: 1.4; }
.news-time { font-size: 0.7rem; color: var(--text-muted); margin-top: 2px; }

/* ── ECON PAGE ── */
.econ-indicator { background: var(--bg); border: 1px solid var(--border); border-radius: 5px; padding: 16px; }
.econ-indicator .ei-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); margin-bottom: 6px; }
.econ-indicator .ei-val { font-size: 1.8rem; font-weight: 300; margin-bottom: 4px; }
.econ-indicator .ei-desc { font-size: 0.78rem; color: var(--text-muted); }

/* ── DM PANEL ── */
.dm-border { border-color: rgba(234,88,12,0.4) !important; }
.event-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-top: 8px; }
.event-btn { font-size: 0.76rem; padding: 7px 8px; text-align: left; border-color: var(--border); color: var(--text); line-height: 1.3; }
.event-btn:hover { border-color: var(--dm-accent); color: var(--dm-accent); background: rgba(234,88,12,0.06); }
.event-btn .ev-desc { display: block; font-size: 0.68rem; color: var(--text-muted); margin-top: 2px; }

/* ── MISC ── */
.ledger-scroll { max-height: 240px; overflow-y: auto; }
canvas { display: block; }
.stock-chart-row { background: #0d0d10; }
.stock-chart-row td { padding: 14px 16px; }
.star-rating { color: var(--accent); letter-spacing: -1px; font-size: 0.85rem; }
.valuation-tag { font-size: 0.68rem; font-weight: 600; }
.val-ov { color: var(--red); } .val-uv { color: var(--green); }
.progress-bar { height: 5px; background: var(--border); border-radius: 3px; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 3px; }
</style>
</head>
<body>

<!-- TOP NAV -->
<nav class="top-nav">
  <div class="nav-brand">⚖ Silver Ledger Group</div>
  <div class="nav-tab active" onclick="showPage('market')">Markets</div>
  <div class="nav-tab" onclick="showPage('economy')">Intelligence</div>
  <div class="nav-tab" onclick="showPage('economy')" style="display:none;">News Feed</div>
  <div class="nav-tab" onclick="showPage('portfolio')">Portfolio</div>
  <div class="nav-tab dm-tab" onclick="showPage('dm')" style="color:var(--dm-accent); border-bottom:2px solid transparent;">👑 DM</div>
  <div class="nav-right">
    <span id="timer-display" style="font-size:0.8rem; color:var(--text-muted);">Next: <span id="timer-val" style="color:var(--text);">00:05</span></span>
    <button id="pause-btn" onclick="togglePause()" style="padding:3px 9px; font-size:0.76rem;">⏸</button>
    <button onclick="saveManualCheckpoint()" class="btn-ghost" style="font-size:0.76rem; padding:3px 8px;">Save</button>
    <button onclick="loadManualCheckpoint()" class="btn-danger" style="font-size:0.76rem; padding:3px 8px;">Restore</button>
    <button onclick="exportToFile()" class="btn-ghost" style="font-size:0.76rem; padding:3px 8px;">Export</button>
    <div class="file-input-wrapper">
      <button class="btn-ghost" style="font-size:0.76rem; padding:3px 8px;">Import</button>
      <input type="file" accept=".json" onchange="importFromFile(event)">
    </div>
  </div>
</nav>

<!-- TICKER -->
<div class="ticker-wrap">
  <div id="ticker-target" class="ticker"></div>
</div>

<!-- ════════════════ MARKET PAGE ════════════════ -->
<div id="page-market" class="page active">
  <!-- Header metrics -->
  <div class="grid-5" style="gap:12px;">
    <div class="panel-sm metric-card">
      <div class="label">Silver Ledger Index</div>
      <div id="fmi-val" class="metric-val">+0.00</div>
      <div id="fmi-change-val" class="metric-sub">0.00% this tick</div>
    </div>
    <div class="panel-sm metric-card">
      <div class="label">Total Market Cap</div>
      <div id="mcap-val" class="metric-val">--</div>
      <div class="metric-sub">All listed companies</div>
    </div>
    <div class="panel-sm metric-card">
      <div class="label">Top Mover</div>
      <div id="gainer-val" class="metric-val up" style="font-size:1rem;">--</div>
      <div id="loser-val" class="metric-sub down">--</div>
    </div>
    <div class="panel-sm metric-card">
      <div class="label">Market Breadth</div>
      <div id="breadth-val" class="metric-val" style="font-size:1rem;">--</div>
      <div id="breadth-desc" class="metric-sub">--</div>
    </div>
    <div class="panel-sm metric-card">
      <div class="label">Market Cycle</div>
      <div id="cycle-phase-val" class="metric-val" style="font-size:1rem; text-transform:capitalize;">--</div>
      <div id="cycle-regime-val" class="metric-sub">--</div>
    </div>
  </div>

  <!-- Main table + sidebar -->
  <div class="grid-2">
    <div class="panel" style="padding: 0; overflow: hidden;">
      <div style="padding: 16px 20px 0; border-bottom: 1px solid var(--border);">
        <h2 style="margin-bottom: 0; padding-bottom: 12px;">Core Asset Board</h2>
      </div>
      <table id="market-table">
        <thead>
          <tr>
            <th style="width:36px; text-align:center;">Pin</th>
            <th class="sortable" onclick="handleSort('rank')"># <span id="si-rank"></span></th>
            <th class="sortable" onclick="handleSort('symbol')">Symbol <span id="si-symbol"></span></th>
            <th class="sortable" onclick="handleSort('name')">Name <span id="si-name"></span></th>
            <th class="sortable" onclick="handleSort('sector')">Sector <span id="si-sector"></span></th>
            <th class="sortable" onclick="handleSort('price')">Price <span id="si-price"></span></th>
            <th class="sortable" onclick="handleSort('marketCap')">Mkt Cap <span id="si-marketCap"></span></th>
            <th class="sortable" onclick="handleSort('change')">Change <span id="si-change"></span></th>
            <th></th>
          </tr>
        </thead>
        <tbody id="market-body"></tbody>
      </table>
    </div>

    <!-- Portfolio sidebar -->
    <div class="panel" style="display:flex; flex-direction:column; gap:14px;">
      <div>
        <h2>Accounts</h2>
        <select id="profile-select" style="width:100%; margin-bottom:10px;"></select>
        <div class="flex-gap">
          <input type="text" id="profile-input" placeholder="Merchant name" style="flex:1;">
          <button onclick="addMerchantProfile()">Create</button>
        </div>
      </div>
      <div id="portfolio-view" style="display:none; border-top:1px solid var(--border); padding-top:14px;">
        <h3 id="active-profile-title" style="color:var(--accent); margin-bottom:10px;">--</h3>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px; font-size:0.87rem; margin-bottom:12px;">
          <div><div class="label">Balance</div><span id="view-cash">0</span> shards</div>
          <div><div class="label">Net Worth</div><strong id="view-net">0</strong> shards</div>
          <div><div class="label">Realized P/L</div><span id="view-realized">0</span></div>
          <div><div class="label">Unrealized P/L</div><span id="view-unrealized">0</span></div>
        </div>
        <canvas id="sparkline" width="300" height="60" style="border-bottom:1px solid var(--border); width:100%;"></canvas>
        <div class="label" style="margin-top:12px; margin-bottom:6px;">Holdings</div>
        <div id="holdings-box" style="font-size:0.83rem; display:flex; flex-direction:column; gap:4px; margin-bottom:14px;"></div>
        <div style="border-top:1px solid var(--border); padding-top:12px;">
          <div class="label" style="margin-bottom:8px;">Order Execution</div>
          <select id="trade-asset" style="width:100%; margin-bottom:8px;"></select>
          <div class="flex-gap" style="margin-bottom:6px;">
            <input type="number" id="trade-amount" min="1" placeholder="Qty" style="width:80px;" onfocus="autoPauseOnTradeInput()">
            <button class="btn-primary" onclick="submitOrder('buy')" style="flex:1;">Acquire</button>
            <button onclick="submitOrder('sell')" style="flex:1; color:var(--text); border-color:var(--border);">Liquidate</button>
          </div>
          <div class="flex-gap" style="margin-bottom:6px;">
            <input type="number" id="trade-spend-amount" placeholder="Spend amount" style="flex:1;" onfocus="autoPauseOnTradeInput()">
            <button onclick="submitOrderMaxSpend()" style="background:#1e3a8a; color:#fff; border-color:#3b82f6; font-size:0.78rem;">Max Buy</button>
          </div>
          <label class="muted" style="display:flex; align-items:center; gap:6px; font-size:0.73rem;">
            <input type="checkbox" id="auto-pause-checkbox" checked> Auto-pause on order entry
          </label>
        </div>
        <div style="border-top:1px solid var(--border); padding-top:12px; margin-top:8px;">
          <div class="label" style="margin-bottom:8px;">Automation</div>
          <div style="display:flex; flex-direction:column; gap:6px; font-size:0.84rem;">
            <div class="flex-between"><span>Limit Buy (drop %):</span><input type="number" id="auto-buy-pct" placeholder="—" style="width:70px; padding:3px 6px;"></div>
            <div class="flex-between"><span>Take Profit (gain %):</span><input type="number" id="auto-sell-pct" placeholder="—" style="width:70px; padding:3px 6px;"></div>
            <div id="sell-gain-projection" style="font-size:0.76rem;"></div>
            <div style="border-top:1px solid var(--border); margin:4px 0 2px; padding-top:6px;" class="muted">Auto-Buy Below Price</div>
            <div class="flex-gap">
              <select id="auto-buy-symbol" style="flex:1; padding:3px 6px;"></select>
              <input type="number" id="auto-buy-price" placeholder="Price" style="width:70px; padding:3px 6px;">
              <input type="number" id="auto-buy-qty" placeholder="Qty" value="5" style="width:55px; padding:3px 6px;">
            </div>
            <button onclick="commitRules()" style="width:100%;">Update Rules</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="panel" style="margin-top:20px; border-color:var(--accent); background:linear-gradient(160deg,#1a1810 0%,#16161a 60%); position:relative; overflow:hidden;">
    <!-- decorative corner marks -->
    <div style="position:absolute;top:10px;left:10px;width:18px;height:18px;border-top:2px solid var(--accent);border-left:2px solid var(--accent);opacity:0.5;"></div>
    <div style="position:absolute;top:10px;right:10px;width:18px;height:18px;border-top:2px solid var(--accent);border-right:2px solid var(--accent);opacity:0.5;"></div>
    <div style="position:absolute;bottom:10px;left:10px;width:18px;height:18px;border-bottom:2px solid var(--accent);border-left:2px solid var(--accent);opacity:0.5;"></div>
    <div style="position:absolute;bottom:10px;right:10px;width:18px;height:18px;border-bottom:2px solid var(--accent);border-right:2px solid var(--accent);opacity:0.5;"></div>
    <div style="max-width:680px; margin:0 auto; padding:12px 24px; text-align:center;">
      <div style="font-size:0.7rem; letter-spacing:0.22em; text-transform:uppercase; color:var(--accent); margin-bottom:10px; opacity:0.7;">Est. Year of the Dragon, Third Century</div>
      <div style="font-size:1.4rem; font-weight:700; letter-spacing:0.06em; color:var(--accent); margin-bottom:4px;">⚖ SILVER LEDGER GROUP</div>
      <div style="font-size:0.7rem; letter-spacing:0.18em; text-transform:uppercase; color:var(--text-muted); margin-bottom:20px;">"Trust Recorded. Wealth Preserved."</div>
      <div style="border-top:1px solid rgba(212,175,55,0.2); margin-bottom:18px;"></div>
      <p style="font-size:0.92rem; color:var(--text); line-height:1.8; margin-bottom:14px;">For over three centuries, the Silver Ledger Group has served as the financial foundation of civilized commerce — providing fair valuations, secure banking, trusted lending, and efficient capital allocation throughout the realm.</p>
      <p style="font-size:0.88rem; color:var(--text-muted); line-height:1.75; margin-bottom:20px;">Through our Grand Ledger Network, thousands of businesses submit financial reports, trade records, production figures, and commercial forecasts. Our analysts and valuation offices use this information to estimate the fair market value of every publicly chartered enterprise — creating a transparent, orderly marketplace where investors may confidently participate in the realm's growth.</p>
      <div style="border-top:1px solid rgba(212,175,55,0.2); margin-bottom:18px;"></div>
      <div style="font-size:0.7rem; letter-spacing:0.15em; text-transform:uppercase; color:var(--accent); margin-bottom:14px; opacity:0.8;">Our Services</div>
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:6px 24px; text-align:left; margin-bottom:20px;">
        <div style="display:flex; align-items:center; gap:8px; font-size:0.83rem; color:var(--text-muted); padding:4px 0;"><span style="color:var(--accent); font-size:0.6rem; flex-shrink:0;">◆</span>Personal and commercial banking</div>
        <div style="display:flex; align-items:center; gap:8px; font-size:0.83rem; color:var(--text-muted); padding:4px 0;"><span style="color:var(--accent); font-size:0.6rem; flex-shrink:0;">◆</span>Merchant and guild financing</div>
        <div style="display:flex; align-items:center; gap:8px; font-size:0.83rem; color:var(--text-muted); padding:4px 0;"><span style="color:var(--accent); font-size:0.6rem; flex-shrink:0;">◆</span>Currency exchange and settlement</div>
        <div style="display:flex; align-items:center; gap:8px; font-size:0.83rem; color:var(--text-muted); padding:4px 0;"><span style="color:var(--accent); font-size:0.6rem; flex-shrink:0;">◆</span>Corporate share issuance and management</div>
        <div style="display:flex; align-items:center; gap:8px; font-size:0.83rem; color:var(--text-muted); padding:4px 0;"><span style="color:var(--accent); font-size:0.6rem; flex-shrink:0;">◆</span>Exchange operations and trade clearing</div>
        <div style="display:flex; align-items:center; gap:8px; font-size:0.83rem; color:var(--text-muted); padding:4px 0;"><span style="color:var(--accent); font-size:0.6rem; flex-shrink:0;">◆</span>Wealth preservation and investment</div>
      </div>
      <div style="border-top:1px solid rgba(212,175,55,0.2); margin-bottom:18px;"></div>
      <p style="font-size:0.88rem; color:var(--text-muted); line-height:1.75; font-style:italic;">The Exchange exists for one purpose: connecting capital with opportunity. When investors purchase shares, businesses gain access to the resources required for expansion. When businesses prosper, commerce flourishes. When commerce flourishes, the realm grows wealthier.</p>
