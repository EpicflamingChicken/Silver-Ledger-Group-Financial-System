function buildChatter(s){
  const ratio=s.price/(impliedValue(s)||s.base);
  const valKey = ratio>1.15?'valuation_over':ratio<0.85?'valuation_under':'valuation_fair';
  const mom=stockMomentum(s);
  const momKey = mom>0.04?'momentum_up':mom<-0.04?'momentum_down':'momentum_flat';
  const sd=state.sectors[s.sector]||{interest:0.5,confidence:0.5};
  const healthPct=((sd.interest||0.5)+(sd.confidence||0.5))/2;
  const secKey = healthPct>=0.6?'sector_favorable':healthPct<=0.4?'sector_pressured':'sector_neutral';
  const chatter=[CHATTER_TEMPLATES[valKey](s), CHATTER_TEMPLATES[momKey](s), CHATTER_TEMPLATES[secKey](s)];
  // Historical-reference line: compare current price to a random point from
  // somewhere in the last 50 ticks — deliberately vague about *which* point,
  // so it reads as "old-timer" chatter rather than a precise data callout.
  const h=s.history||[];
  if(h.length>=6){
    const lookback=Math.min(50,h.length-1);
    const idx=h.length-1-(1+Math.floor(Math.random()*lookback));
    const past=h[Math.max(0,idx)];
    const diff=(s.price-past)/(past||s.price);
    const histKey = diff>0.05?'historical_up':diff<-0.05?'historical_down':'historical_flat';
    chatter.push(CHATTER_TEMPLATES[histKey](s));
  }
  return chatter;
}


// News fires once every 12–48 ticks, chosen randomly each time
let _nextNewsTick = 0;
// Random market shocks (if enabled) fire roughly 1/8th as often as news — 96–384 ticks
let _nextShockTick = 96 + Math.floor(Math.random()*289);

function maybeFireAutoShock(){
  if(!(state.settings&&state.settings.autoShocks))return;
  if(state.tickCount < _nextShockTick) return;
  _nextShockTick = state.tickCount + 96 + Math.floor(Math.random()*289);
  triggerRandomShock(true);
}

function generateNews(){
  // Only fire on the scheduled tick
  if(state.tickCount < _nextNewsTick) return;
  // Schedule next news event 12–48 ticks from now
  _nextNewsTick = state.tickCount + 12 + Math.floor(Math.random()*37);

  const e=state.economy;
  const items=[];
  const t=newsTime();
  // Decide which category fires this issue (weighted)
  const roll=Math.random();

  if(roll<0.30){
    // Economy / macro headline — also nudges the relevant dial a little further
    // in the direction the headline describes, so news has real consequences.
    if(e.growth>0.05){items.push({src:'economy',headline:NEWS_TEMPLATES.economy_up(e),time:t,type:'economy'});e.growth=clamp(e.growth+0.015,-0.5,0.5);}
    else if(e.growth<-0.05){items.push({src:'economy',headline:NEWS_TEMPLATES.economy_down(e),time:t,type:'economy'});e.growth=clamp(e.growth-0.015,-0.5,0.5);}
    else if(e.inflation>0.045){items.push({src:'economy',headline:NEWS_TEMPLATES.inflation_up(e),time:t,type:'economy'});e.inflation=clamp(e.inflation+0.003,0,0.08);}
    else if(e.inflation<0.01){items.push({src:'economy',headline:NEWS_TEMPLATES.inflation_down(e),time:t,type:'economy'});e.inflation=clamp(e.inflation-0.003,0,0.08);}
    else if(e.interestRates>0.06){items.push({src:'economy',headline:NEWS_TEMPLATES.rates_up(e),time:t,type:'economy'});e.interestRates=clamp(e.interestRates+0.0025,0,0.12);}
    else if(e.interestRates<0.015){items.push({src:'economy',headline:NEWS_TEMPLATES.rates_down(e),time:t,type:'economy'});e.interestRates=clamp(e.interestRates-0.0025,0,0.12);}
    else if(e.globalTrade>0.65){items.push({src:'trade',headline:NEWS_TEMPLATES.trade_up(e),time:t,type:'trade'});e.globalTrade=clamp(e.globalTrade+0.015,0,1);}
    else if(e.globalTrade<0.35){items.push({src:'trade',headline:NEWS_TEMPLATES.trade_down(e),time:t,type:'trade'});e.globalTrade=clamp(e.globalTrade-0.015,0,1);}
    else if(e.stability>0.7){items.push({src:'civic',headline:NEWS_TEMPLATES.stability_up(e),time:t,type:'civic'});e.stability=clamp(e.stability+0.015,0,1);}
    else if(e.stability<0.35){items.push({src:'civic',headline:NEWS_TEMPLATES.stability_down(e),time:t,type:'civic'});e.stability=clamp(e.stability-0.015,0,1);}
    else items.push({src:'economy',headline:NEWS_TEMPLATES.economy_up(e),time:t,type:'economy'});
  } else if(roll<0.55){
    // Sector headline — reinforces the sector's current offset a little, so a
    // sector that's already running hot (or cold) gets a small extra push.
    const sec=pick(SECTORS);
    const sd=state.sectors[sec];
    if(sd.confidence>0.6||sd.interest>0.6){
      items.push({src:'sector',headline:NEWS_TEMPLATES.sector_up(sec),time:t,type:'sector',sector:sec});
      sd.offset=clamp((sd.offset||0)+rand(0.01,0.03),-0.6,0.6);
    } else if(sd.confidence<0.4||sd.interest<0.4){
      items.push({src:'sector',headline:NEWS_TEMPLATES.sector_down(sec),time:t,type:'sector',sector:sec});
      sd.offset=clamp((sd.offset||0)-rand(0.01,0.03),-0.6,0.6);
    } else
      items.push({src:'sector',headline:NEWS_TEMPLATES.sector_up(sec),time:t,type:'sector',sector:sec});
  } else if(roll<0.85){
    // Company headline — pick the biggest mover, and give it a small follow-through nudge
    const movers=[...state.stocks].sort((a,b)=>Math.abs(b.change)-Math.abs(a.change));
    const s=movers[Math.floor(Math.random()*3)];
    if(s){
      let hl;
      if(s.change>1.5){hl=NEWS_TEMPLATES.company_up(s);s.growthOffset=clamp((s.growthOffset||0)+rand(0.01,0.025),-0.6,0.6);}
      else if(s.change<-1.5){hl=NEWS_TEMPLATES.company_down(s);s.growthOffset=clamp((s.growthOffset||0)-rand(0.01,0.025),-0.6,0.6);}
      else if((s.growthOffset||0)>0.03){hl=NEWS_TEMPLATES.company_debt_up(s);s.growthOffset=clamp(s.growthOffset+rand(0.005,0.015),-0.6,0.6);}
      else if((s.growthOffset||0)<-0.03){hl=NEWS_TEMPLATES.company_debt_down(s);s.growthOffset=clamp(s.growthOffset-rand(0.005,0.015),-0.6,0.6);}
      else {
        const lcTpl=[NEWS_TEMPLATES.lc_startup,NEWS_TEMPLATES.lc_growth,NEWS_TEMPLATES.lc_mature,NEWS_TEMPLATES.lc_declining];
        hl=pick(lcTpl)(s);
        s.growthOffset=clamp((s.growthOffset||0)+rand(-0.01,0.01),-0.6,0.6);
      }
      items.push({src:'company',headline:hl,time:t,type:'company',symbol:s.symbol});
    }
  } else {
    // Analyst report — richer format with target price and rating flavour
    const s=pick(state.stocks);
    const firm=pick(NEWS_SOURCES.analyst);
    const ar=analystTargetRange(s);
    const midTarget=Math.round((ar.lo+ar.hi)/2);
    const rating=pick(['Outperform','Buy','Hold','Underperform','Strong Buy','Market Perform','Sell']);
    const action=pick([
      `Initiates coverage with ${rating} rating, target ${midTarget} shards`,
      `Reiterates ${rating}, raises target to ${midTarget} shards`,
      `Downgrades to ${rating}, cuts target to ${midTarget} shards`,
      `Upgrades to ${rating}, target ${midTarget} shards`,
      `Maintains ${rating}, adjusts target to ${midTarget} shards`,
      `Places ${rating} on watch, cites ${s.sector} sector headwinds`,
      `Resumes coverage with ${rating}, notes ${s.sector} tailwinds`,
    ]);
    const hl=`${firm}: ${s.symbol} — ${s.name} — ${action}`;
    state.analysts.unshift({headline:hl,time:t,symbol:s.symbol,sector:s.sector});
    if(state.analysts.length>30)state.analysts.pop();
  }

  if(items.length>0){
    state.news.unshift(...items);
    if(state.news.length>80)state.news=state.news.slice(0,80);
  }
}

function addCompanyNews(s, type, headline){
  const item={src:'event',headline,time:newsTime(),type,symbol:s.symbol};
  state.news.unshift(item);
  if(!s.news)s.news=[];
  s.news.unshift(item);
  if(s.news.length>8)s.news.pop();
}

