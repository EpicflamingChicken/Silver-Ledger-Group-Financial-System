function forceCyclePhase(phase){
  // Algorithmic version: nudge the FMI toward a phase-typical level and bias
  // the economy dials so the cosmetic Cycle/Economy pages match the injection.
  const fmiTarget={expansion:104,boom:114,slowdown:97,recession:85,recovery:96};
  const econTarget={
    expansion: {growth:0.06, inflation:0.025,interestRates:0.035,globalTrade:0.58, stability:0.65},
    boom:      {growth:0.16, inflation:0.04, interestRates:0.045,globalTrade:0.70, stability:0.72},
    slowdown:  {growth:-0.02,inflation:0.035,interestRates:0.05, globalTrade:0.45, stability:0.52},
    recession: {growth:-0.14,inflation:0.05, interestRates:0.065,globalTrade:0.30, stability:0.36},
    recovery:  {growth:0.02, inflation:0.03, interestRates:0.04, globalTrade:0.48, stability:0.55},
  };
  if(fmiTarget[phase]!==undefined){
    const delta=(fmiTarget[phase]-state.market.fmi)*0.5;
    state.market.fmi=Math.max(15,+(state.market.fmi+delta).toFixed(2));
  }
  if(econTarget[phase]) Object.assign(state.economy, econTarget[phase]);
  state.market.phase=phase;
  state.market.regime = (phase==='boom'||phase==='expansion')?'bull':(phase==='recession'||phase==='slowdown')?'bear':'neutral';
  const phaseNews={expansion:'📈 DM Injection: Economic expansion begins',boom:'🚀 DM Injection: Market enters boom phase',slowdown:'📉 DM Injection: Growth is slowing',recession:'🔴 DM Injection: Recession imposed by DM',recovery:'🌱 DM Injection: Recovery phase begins'};
  state.news.unshift({src:'dm',headline:phaseNews[phase]||phase,time:newsTime(),type:'dm'});
  commitToStorage(); refreshUI();
}
function triggerRandomShock(silent){
  const isCrisis=Math.random()>0.45;
  // Most shocks are minor jolts. Roughly 1-in-5 shocks (and shocks fire ~every
  // 240 ticks) are "major" — works out to a >10pt move roughly once per 1000 ticks.
  const isMajor=Math.random()<0.18;
  const shockMagnitude=isMajor?+(10+Math.random()*8).toFixed(2):+(1+Math.random()*5).toFixed(2);
  if(isCrisis){
    state.market.fmi=Math.max(15,+(state.market.fmi*(1-shockMagnitude/100)).toFixed(2));
    state.news.unshift({src:'event',headline:`⚡ MARKET SHOCK — Index drops ${shockMagnitude}% on sudden crisis`,time:newsTime(),type:'event'});
    if(!silent)alert(`⚠️ SHOCK EVENT: Deep-roads collapse or regional embargo! SLI dropped by ${shockMagnitude}%`);
  } else {
    state.market.fmi=+(state.market.fmi*(1+shockMagnitude/100)).toFixed(2);
    state.news.unshift({src:'event',headline:`⚡ MARKET SHOCK — Index surges ${shockMagnitude}% on windfall news`,time:newsTime(),type:'event'});
    if(!silent)alert(`✨ SHOCK EVENT: Sovereign bullion reserve discovered! SLI raised by ${shockMagnitude}%`);
  }
  commitToStorage(); refreshUI();
}
function toggleAutoShocks(checked){
  if(!state.settings)state.settings={};
  state.settings.autoShocks=!!checked;
  if(checked) _nextShockTick = state.tickCount + 96 + Math.floor(Math.random()*289);
  commitToStorage();
}
function toggleDividends(checked){
  if(!state.settings)state.settings={};
  state.settings.dividendsEnabled=!!checked;
  commitToStorage();
}
function nudgeEconomy(key,delta){
  const limits={growth:[-0.5,0.5],inflation:[0,0.08],interestRates:[0,0.12],globalTrade:[0,1],stability:[0,1]};
  const [lo,hi]=limits[key]||[0,1];
  state.economy[key]=clamp((state.economy[key]||0)+delta,lo,hi);
  commitToStorage(); refreshUI();
}
function adjustSectorSentiment(sec,delta){
  if(!state.sectors[sec])return;
  state.sectors[sec].offset=(state.sectors[sec].offset||0)+delta;
  state.sectors[sec].confidence=clamp(state.sectors[sec].confidence+delta*0.6,0.05,0.95);
  state.sectors[sec].interest=clamp(state.sectors[sec].interest+delta*0.6,0.05,0.95);
  // Immediate partial price tick visualization, same as direct sector injection
  state.stocks.forEach(stock=>{
    if(stock.sector===sec){
      const oldPrice=stock.price||stock.base;
      stock.price=Math.max(0.5,+(stock.price*(1+delta)).toFixed(2));
      stock.change=+(((stock.price-oldPrice)/oldPrice)*100).toFixed(2);
      stock.marketCap=stock.price*stock.sharesOutstanding;
    }
  });
  const src=delta>0?'DM Boost':'DM Stress';
  state.news.unshift({src:'dm',headline:`${src}: ${sec} sector sentiment injected by DM`,time:newsTime(),type:'dm'});
  updateRanks();
  commitToStorage(); refreshUI();
}
function adjustStockFundamentals(sym,type,delta){
  const s=state.stocks.find(st=>st.symbol===sym);
  if(!s)return;
  // Both 'sentiment' and 'revenue' injections feed the same decaying growthOffset,
  // just at different magnitudes — sentiment is a lighter touch, revenue is sustained.
  s.growthOffset=(s.growthOffset||0)+delta;
  const oldPrice=s.price||s.base;
  s.price=Math.max(0.5,+(s.price*(1+delta)).toFixed(2));
  s.change=+(((s.price-oldPrice)/oldPrice)*100).toFixed(2);
  s.marketCap=s.price*s.sharesOutstanding;
  updateRanks();
  commitToStorage(); refreshUI();
}
function triggerWorldEvent(id){
  const ev=WORLD_EVENTS.find(e=>e.id===id);
  if(!ev)return;
  const fx=ev.effects;
  SECTORS.forEach(sec=>{
    if(!fx[sec])return;
    const sf=fx[sec];
    if(sf.sent!==undefined)adjustSectorSentiment(sec,sf.sent);
    if(sf.conf!==undefined)state.sectors[sec].confidence=clamp(state.sectors[sec].confidence+sf.conf,0.05,0.95);
    if(sf.rev!==undefined) state.stocks.filter(s=>s.sector===sec).forEach(s=>{s.growthOffset=(s.growthOffset||0)+sf.rev;});
  });
  if(fx.growth!==undefined)     state.economy.growth=clamp(state.economy.growth+fx.growth,-0.5,0.5);
  if(fx.inflation!==undefined)  state.economy.inflation=clamp(state.economy.inflation+fx.inflation,0,0.15);
  if(fx.globalTrade!==undefined)state.economy.globalTrade=clamp(state.economy.globalTrade+fx.globalTrade,0,1);
  if(fx.stability!==undefined)  state.economy.stability=clamp(state.economy.stability+fx.stability,0,1);
  if(fx.globalSentiment!==undefined) state.stocks.forEach(s=>{s.growthOffset=(s.growthOffset||0)+fx.globalSentiment;});
  const evHL=ev.label.replace(/\p{Emoji}/gu,'').trim();
  state.news.unshift({src:'event',headline:`⚡ WORLD EVENT — ${evHL}: ${ev.desc}`,time:newsTime(),type:'event'});
  alert(`⚡ WORLD EVENT: ${ev.label}\n"${ev.desc}"\n\nEffects will ripple through the market over the next several ticks.`);
  updateRanks();
  commitToStorage(); refreshUI();
}

// ═══════════════════════════════════════════════════════════
//  DISPLAY HELPERS (hide simulation internals)
// ═══════════════════════════════════════════════════════════
function qualityRating(vol){
  // Lower historical volatility = higher "quality" rating
  if(vol<=6) return'<span class="up">★★★★★</span>';
  if(vol<=9) return'<span class="up">★★★★</span><span class="muted">★</span>';
  if(vol<=12)return'<span style="color:var(--yellow);">★★★</span><span class="muted">★★</span>';
  if(vol<=15)return'<span style="color:var(--yellow);">★★</span><span class="muted">★★★</span>';
  return'<span class="down">★</span><span class="muted">★★★★</span>';
}
function combinedOffset(s){
  return ((state.sectors[s.sector]||{}).offset||0) + (s.growthOffset||0);
}
function moodLabel(s){
  const off=combinedOffset(s);
  if(off>0.05) return '<span class="badge-mood-bullish">▲ Bullish</span>';
  if(off<-0.05)return '<span class="badge-mood-bearish">▼ Bearish</span>';
  return '<span class="badge-mood-neutral">— Neutral</span>';
}
function stockMomentum(s){
  const h=s.history||[];
  if(h.length<2)return 0;
  const n=Math.min(5,h.length-1);
  return (h[h.length-1]-h[h.length-1-n])/(h[h.length-1-n]||1);
}
function momentumLabel(s){
  const mom=stockMomentum(s);
  if(mom>0.04) return'<span class="up">↑ Uptrend</span>';
  if(mom<-0.04)return'<span class="down">↓ Downtrend</span>';
  return'<span class="muted">→ Sideways</span>';
}
function impliedValue(s){
  // "Fair value" analogue for the algorithmic model: what the formula targets
  // before this tick's random volatility component is applied.
  const off=combinedOffset(s);
  return s.base*(state.market.fmi/100)*(1+off);
}
function analystTargetRange(s){
  // A range, not a point estimate — derived from implied value but with a
  // built-in spread, so it can't be used to back out the exact formula output.
  // Spread scales a bit with the asset's own volatility, but stays modest —
  // except occasionally, when analysts simply can't agree on this one.
  const iv=impliedValue(s);
  let spread=rand(0.015,0.03)+(s.vol/180);
  let noConsensus=false;
  if(Math.random()<0.06){
    spread*=rand(2.5,4.5);
    noConsensus=true;
  }
  const lo=iv*(1-spread), hi=iv*(1+spread*rand(0.9,1.2));
  return {lo:Math.max(0.5,lo), hi:Math.max(1,hi), noConsensus};
}
function analystTargetLabel(s){
  const r=analystTargetRange(s);
  const range=`${r.lo.toFixed(0)} – ${r.hi.toFixed(0)}`;
  return r.noConsensus ? `${range} <span class="muted" style="font-size:0.7rem;">(no clear consensus)</span>` : range;
}
function econDisplayVal(key,v){
  if(key==='growth')    return (v*100).toFixed(1)+'%';
  if(key==='inflation') return (v*100).toFixed(1)+'%';
  if(key==='interestRates') return (v*100).toFixed(1)+'%';
  if(key==='globalTrade')  return (v*100).toFixed(0)+'%';
  if(key==='stability')    return (v*100).toFixed(0)+'%';
  return v;
}
function econGaugeColor(key,v){
  if(key==='growth')    return v>=0?'var(--green)':'var(--red)';
  if(key==='inflation') return v<0.02?'var(--green)':v<0.045?'var(--yellow)':'var(--red)';
  if(key==='interestRates')return v<0.025?'var(--green)':v<0.05?'var(--yellow)':'var(--red)';
  if(key==='globalTrade')  return v>0.5?'var(--green)':'var(--red)';
  if(key==='stability')    return v>0.5?'var(--green)':'var(--red)';
  return 'var(--text)';
}
function econStatus(key,v){
  if(key==='growth')    return v>0.05?'Expanding':v<-0.05?'Contracting':'Stable';
  if(key==='inflation') return v<0.012?'Low':v<0.035?'Moderate':v<0.055?'Elevated':'High';
  if(key==='interestRates')return v<0.015?'Accommodative':v<0.04?'Neutral':v<0.065?'Elevated':'Restrictive';
  if(key==='globalTrade')  return v>0.65?'Strong':v>0.45?'Moderate':'Weak';
  if(key==='stability')    return v>0.65?'Stable':v>0.45?'Moderate':'Volatile';
  return '';
}

