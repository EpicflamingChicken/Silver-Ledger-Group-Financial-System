  sectors: {},   // per-sector: offset (sustained, decaying), interest, confidence (cosmetic)
  stocks: [],
  market: {fmi:100, lastFmi:100, countdown:5, maxCountdown:5, momentum:0, fmiHistory:[100], phase:'expansion', regime:'neutral'},
  profiles: [], activeIdx:-1, ledger:[], tickCount:0,
  news: [],      // generated news items
  analysts: []   // analyst reports
};
