// ═══════════════════════════════════════════════════════════
//  INIT
// ═══════════════════════════════════════════════════════════
function clamp(v,lo,hi){return Math.min(hi,Math.max(lo,v));}
function rand(lo,hi){return lo+Math.random()*(hi-lo);}

function initSectors(){
  SECTORS.forEach(sec=>{
    if(!state.sectors[sec]) state.sectors[sec]={
      offset: 0,              // sustained price-multiplier offset (decays)
      interest: rand(0.4,0.6),// cosmetic, drives sector conditions page
      confidence: rand(0.4,0.6)
    };
  });
}

function buildStock(t){
  return {
    symbol:t.s, name:t.n, base:t.b, price:t.b,
    vol:t.v, sector:t.sec, sharesOutstanding:t.shares,
    growthOffset:0,  // sustained DM-injected offset (decays)
    volNoise:0,      // smoothed per-tick volatility component (mean-reverting)
    history:[t.b,t.b], change:0, pinned:false, rank:0, prevRank:0,
    marketCap:t.b*t.shares, news:[]
  };
}

function buildNewState(){
  state.economy = {growth:0.0, inflation:0.025, interestRates:0.035, globalTrade:0.5, stability:0.6};
  state.sectors = {};
  initSectors();
  state.stocks  = ASSET_TEMPLATES.map(buildStock);
  state.market  = {fmi:100, lastFmi:100, countdown:5, maxCountdown:5, momentum:0, fmiHistory:[100], phase:'expansion', regime:'neutral'};
  state.profiles=[]; state.ledger=[]; state.activeIdx=-1; state.tickCount=0;
  state.news=[]; state.analysts=[];
  state.settings={autoShocks:false,dividendsEnabled:true};
  updateRanks();
}

function migrateState(){
  if(!state.economy) state.economy={growth:0,inflation:0.025,interestRates:0.035,globalTrade:0.5,stability:0.6};
  if(!state.sectors || !state.sectors[SECTORS[0]] || state.sectors[SECTORS[0]].offset===undefined){
    const old=state.sectors||{};
    state.sectors={};
    initSectors();
    SECTORS.forEach(sec=>{
      if(old[sec]){
        state.sectors[sec].offset = old[sec].sentimentOffset || old[sec].offset || 0;
      }
    });
  }
  if(!state.tickCount) state.tickCount=0;
  if(!state.news) state.news=[];
  if(!state.analysts) state.analysts=[];
  if(!state.settings) state.settings={autoShocks:false,dividendsEnabled:true};
  if(state.settings.dividendsEnabled===undefined) state.settings.dividendsEnabled=true;
  // Migrate stocks moved to the Guilds sector
  const toGuilds=['TMGT','STON','SAIL','VINT','SMTH','CGMA','INNK'];
  state.stocks.forEach(s=>{
    if(toGuilds.includes(s.symbol)&&s.sector!=='Guilds') s.sector='Guilds';
    if(s.sector==='Mercenary') s.sector='Defense and Security';
    if(s.volNoise===undefined) s.volNoise=0;
  });
  if(!state.market.fmiHistory) state.market.fmiHistory=[state.market.fmi||100];
  if(!state.market.phase) state.market.phase='expansion';
  if(!state.market.regime) state.market.regime='neutral';
  if(!state.market.maxCountdown) state.market.maxCountdown=5;
  state.stocks.forEach(s=>{
    if(s.growthOffset===undefined) s.growthOffset = s.revenueBoostOffset || 0;
    if(s.volNoise===undefined) s.volNoise = 0;
    if(!s.sharesOutstanding) s.sharesOutstanding=400;
    if(!s.marketCap) s.marketCap=s.price*s.sharesOutstanding;
    if(!s.news) s.news=[];
    if(s.pinned===undefined) s.pinned=false;
  });
  updateRanks();
}

function initExchange(){
  const cache=localStorage.getItem(STORAGE_KEY);
  if(cache){
    try{
      const p=JSON.parse(cache);
      if(!p||!p.stocks||p.stocks.length===0){buildNewState();}
      else{state=p; migrateState(); injectNewStocks();}
    }catch(e){buildNewState();}
  } else {buildNewState();}

  document.getElementById('dm-timer-max').value=state.market.maxCountdown||5;
  document.getElementById('dm-timer-current').value=state.market.countdown||5;
  buildEventGrid();
  refreshUI();
  beginClock();
}

function injectNewStocks(){
  // Add any stocks from ASSET_TEMPLATES that don't yet exist in the saved state
  const existing=new Set(state.stocks.map(s=>s.symbol));
  ASSET_TEMPLATES.forEach(t=>{
    if(!existing.has(t.s)) state.stocks.push(buildStock(t));
  });
  // Also ensure all new sectors are initialised
  initSectors();
  updateRanks();
}

// ═══════════════════════════════════════════════════════════
//  SIMULATION ENGINE (algorithmic — FMI random walk + offsets)
// ═══════════════════════════════════════════════════════════
function processMarketTick(){
  state.market.lastFmi=state.market.fmi;
  state.tickCount=(state.tickCount||0)+1;

  driftEconomy();
  driftSectorConditions();

  // Core algorithmic index formula: cyclical bias + momentum carry-over + mean reversion to 100
  const cycleBias=(Math.random()-0.502)*3.5;
  const momentumFactor=(state.market.momentum||0)*0.04;
  const meanReversion=(100-state.market.fmi)*0.015;
  // Small narrative tie-in so the Economy dials have a felt effect on the index
  const econBias=(state.economy.growth||0)*1.4;
  state.market.fmi=Math.max(15,+(state.market.fmi+cycleBias+momentumFactor+meanReversion+econBias).toFixed(2));

  if(!state.market.fmiHistory)state.market.fmiHistory=[];
  state.market.fmiHistory.push(state.market.fmi);
  if(state.market.fmiHistory.length>40)state.market.fmiHistory.shift();

  let netUps=0, netDowns=0;
  const decayFactor=0.85; // controls how fast DM-injected offsets normalize (higher = more sustained)

  state.stocks.forEach(stock=>{
    // Smoothed volatility: drift toward a new random target each tick instead of an
    // independent jump every time — keeps the overall vol band but stops the
    // "swing 18% one way, swing 18% the other way next tick" whiplash.
    const sectorOffset=(state.sectors[stock.sector]||{}).offset||0;
    const assetOffset=stock.growthOffset||0;
    const mood=sectorOffset+assetOffset;
    // Mood gives the volatility target a gentle directional lean — a bullish
    // stock is a little more likely to roll positive ticks and vice versa,
    // on top of the static price-level effect of the offsets themselves.
    // Anti-snowball: if price has already run hard in the direction mood is
    // pushing, the bias fades out — it can kick off a move but won't keep
    // piling onto one that's already extended.
    const deviation=(stock.price||stock.base)/stock.base-1; // how far price already sits from its base
    const runningWithMood = (mood>0 && deviation>0) || (mood<0 && deviation<0);
    const snowballDamp = runningWithMood ? clamp(1-Math.abs(deviation)/0.4, 0, 1) : 1;
    const moodBias=clamp(mood*stock.vol*1.5,-stock.vol*0.5,stock.vol*0.5)*snowballDamp;
    const volTarget=clamp((Math.random()*(stock.vol*2))-stock.vol+moodBias,-stock.vol,stock.vol);
    stock.volNoise=clamp((stock.volNoise||0)+(volTarget-stock.volNoise)*0.35,-stock.vol,stock.vol);
    const randBetweenVol=stock.volNoise;

    const combinedSustainedShiftMultiplier=1+sectorOffset+assetOffset;

    let calculatedPrice=stock.base*(state.market.fmi/100)*((100+randBetweenVol)/100)*combinedSustainedShiftMultiplier;

    const overvaluationThreshold=stock.base*2.5;
    if(calculatedPrice>overvaluationThreshold){
      const overshoot=calculatedPrice-overvaluationThreshold;
      calculatedPrice=overvaluationThreshold+(overshoot*0.2);
    }

    const old=stock.price||stock.base;
    stock.price=Math.max(0.5,+calculatedPrice.toFixed(2));
    stock.change=+(((stock.price-old)/old)*100).toFixed(2);
    stock.marketCap=stock.price*stock.sharesOutstanding;

    recordHistory(stock);

    if(stock.change>0)netUps++;
    else if(stock.change<0)netDowns++;

    // Sustained adjustments decay back toward normal
    stock.growthOffset=+(stock.growthOffset*decayFactor).toFixed(4);
    if(Math.abs(stock.growthOffset)<0.005)stock.growthOffset=0;
  });

  // Decay sector offsets back toward normalization
  SECTORS.forEach(sec=>{
    const sd=state.sectors[sec];
    sd.offset=+(sd.offset*decayFactor).toFixed(4);
    if(Math.abs(sd.offset)<0.005)sd.offset=0;
  });

  state.market.momentum=netUps-netDowns;
  updateCyclePhase();

  generateNews();
  maybeFireAutoShock();
  payDividendsIfDue();
  updateRanks();
  evaluateAutomation();
  appendHistorySnapshots();
  commitToStorage();
  refreshUI();

  for(let sym in openGraphs){if(openGraphs[sym])drawInlineDetailChart(sym);}
}

function recordHistory(s){
  if(!s.history)s.history=[];
  s.history.push(s.price);
  if(s.history.length>60)s.history.shift();
}

// ─── ECONOMY & SECTOR DRIFT (simple algorithmic random walks) ───
function driftEconomy(){
  const e=state.economy;
  e.growth        = clamp(e.growth        + (0    - e.growth       )*0.03 + (Math.random()-0.5)*0.012, -0.40, 0.40);
  // Inflation targets a realistic ~2.5% with a modest band (0-8%), and drifts
  // slowly — real economies don't swing from 0% to 15% inflation casually.
  e.inflation     = clamp(e.inflation     + (0.025 - e.inflation    )*0.04 + (Math.random()-0.5)*0.0025, 0.00, 0.08);
  e.interestRates = clamp(e.interestRates + (0.035 - e.interestRates)*0.03 + (Math.random()-0.5)*0.003,  0.00, 0.12);
  e.globalTrade   = clamp(e.globalTrade   + (0.5  - e.globalTrade  )*0.03 + (Math.random()-0.5)*0.012,  0.00, 1.00);
  e.stability     = clamp(e.stability     + (0.6  - e.stability    )*0.03 + (Math.random()-0.5)*0.010,  0.00, 1.00);
}

function driftSectorConditions(){
  SECTORS.forEach(sec=>{
    const sd=state.sectors[sec];
    sd.interest   = clamp(sd.interest   + (0.5-sd.interest  )*0.03 + (Math.random()-0.5)*0.02 + sd.offset*0.3, 0.05, 0.95);
    sd.confidence = clamp(sd.confidence + (0.5-sd.confidence)*0.03 + (Math.random()-0.5)*0.02 + sd.offset*0.3, 0.05, 0.95);
  });
}

// ─── CYCLE PHASE (derived from recent FMI trend — purely descriptive) ───
function updateCyclePhase(){
  const h=state.market.fmiHistory||[];
  const fmi=state.market.fmi;
  const slope = h.length>=6 ? (h[h.length-1]-h[h.length-6])/5 : 0;
  let phase;
  if(slope>0.6)       phase = fmi>105 ? 'boom'      : 'recovery';
  else if(slope>0.05) phase = 'expansion';
  else if(slope<-0.6) phase = fmi<95  ? 'recession' : 'slowdown';
  else if(slope<-0.05)phase = 'slowdown';
  else                 phase = fmi>=100 ? 'expansion' : 'recovery';
  state.market.phase=phase;
  const mom=state.market.momentum||0;
  state.market.regime = mom>4 ? 'bull' : mom<-4 ? 'bear' : 'neutral';
}

