//  TRADING
// ═══════════════════════════════════════════════════════════
function executeTradeAction(profile,symbol,qty,action){
  const s=state.stocks.find(st=>st.symbol===symbol);
  if(!s||qty<=0)return;
  const cost=s.price*qty;
  if(action==='buy'){
    profile.cash-=cost;
    if(!profile.holdings[symbol])profile.holdings[symbol]={qty:0,avg:0};
    const pc=profile.holdings[symbol].qty*profile.holdings[symbol].avg;
    profile.holdings[symbol].qty+=qty;
    profile.holdings[symbol].avg=(pc+cost)/profile.holdings[symbol].qty;
    logLedger(profile.name,'BUY',symbol,qty,s.price,0,'');
  } else {
    const h=profile.holdings[symbol];
    if(!h||h.qty<qty)return alert("Insufficient holdings for this sale.");
    const profit=(s.price-h.avg)*qty;
    profile.cash+=cost; h.qty-=qty;
    profile.realized=(profile.realized||0)+profit;
    if(h.qty<=0)delete profile.holdings[symbol];
    logLedger(profile.name,'SELL',symbol,qty,s.price,profit,'');
  }
}
function submitOrder(type){
  if(state.activeIdx===-1)return;
  const p=state.profiles[state.activeIdx];
  const sym=document.getElementById('trade-asset').value;
  const qty=parseInt(document.getElementById('trade-amount').value);
  if(!qty||qty<=0)return alert("Specify valid quantity.");
  if(type==='sell'&&(!p.holdings[sym]||p.holdings[sym].qty<qty))return alert("Insufficient holdings.");
  executeTradeAction(p,sym,qty,type);
  commitToStorage(); refreshUI();
}
function submitOrderMaxSpend(){
  if(state.activeIdx===-1)return alert("Select an account first.");
  const p=state.profiles[state.activeIdx];
  const sym=document.getElementById('trade-asset').value;
  const budget=parseFloat(document.getElementById('trade-spend-amount').value);
  if(!budget||budget<=0)return alert("Enter a valid budget.");
  const s=state.stocks.find(st=>st.symbol===sym);
  if(!s)return;
  const qty=Math.floor(budget/s.price);
  if(qty<=0)return alert("Budget too small for 1 share.");
  executeTradeAction(p,sym,qty,'buy');
  document.getElementById('trade-spend-amount').value='';
  commitToStorage(); refreshUI();
}
function portfolioSubmitOrder(type){
  const sel=document.getElementById('portfolio-page-select');
  const idx=parseInt(sel.value);
  if(isNaN(idx)||!state.profiles[idx])return alert("Select an account.");
  const p=state.profiles[idx];
  const sym=document.getElementById('portfolio-trade-asset').value;
  const qty=parseInt(document.getElementById('portfolio-trade-qty').value);
  if(!qty||qty<=0)return alert("Specify valid quantity.");
  if(type==='sell'&&(!p.holdings[sym]||p.holdings[sym].qty<qty))return alert("Insufficient holdings.");
  executeTradeAction(p,sym,qty,type);
  commitToStorage(); refreshUI();
}
function evaluateAutomation(){
  if(!state.profiles)return;
  state.profiles.forEach(p=>{
    if(!p.rules)return;
    state.stocks.forEach(s=>{
      if(p.rules.buyDrop!=null&&s.change<=-p.rules.buyDrop) executeTradeAction(p,s.symbol,10,'buy');
      if(p.rules.sellGain!=null&&p.holdings[s.symbol]){
        const h=p.holdings[s.symbol];
        if(((s.price-h.avg)/h.avg)*100>=p.rules.sellGain) executeTradeAction(p,s.symbol,h.qty,'sell');
      }
      // Auto-buy below an absolute price threshold for a specific stock
      if(p.rules.buyBelow&&p.rules.buyBelow.symbol===s.symbol&&p.rules.buyBelow.price!=null
         &&s.price<=p.rules.buyBelow.price&&p.rules.buyBelow.qty>0){
        executeTradeAction(p,s.symbol,p.rules.buyBelow.qty,'buy');
      }
    });
  });
}

