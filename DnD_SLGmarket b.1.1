function updateRanks(){
  if(!state.stocks)return;
  [...state.stocks].sort((a,b)=>(b.marketCap||0)-(a.marketCap||0)).forEach((s,i)=>{
    s.prevRank=s.rank!==undefined?s.rank:i;
    s.rank=i;
  });
}

