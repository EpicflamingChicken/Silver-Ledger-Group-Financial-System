function showPage(id){
  if(id==='news') id='economy'; // News is now merged into the Intelligence tab
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  const tabs=document.querySelectorAll('.nav-tab');
  tabs.forEach(t=>{if(t.getAttribute('onclick')===`showPage('${id}')`)t.classList.add('active');});
  if(id==='economy'){renderEconomyPage();}
  if(id==='portfolio'){renderPortfolioPage();}
  if(id==='dm'){renderDMPage();}
}

function refreshUI(){
  try{
    if(!state||!state.stocks||state.stocks.length===0)return;
    renderTicker();
    renderMarketPage();
    // refresh active tab passively
    const activePage=document.querySelector('.page.active');
    if(activePage){
      const pid=activePage.id.replace('page-','');
      if(pid==='economy')renderEconomyPage();
      if(pid==='news')renderNewsPage();
      if(pid==='portfolio')renderPortfolioPage();
      if(pid==='dm')renderDMPage();
    }
  }catch(err){console.error('UI error:',err);}
}

function isOwned(symbol){
  if(state.activeIdx===-1)return false;
  const p=state.profiles[state.activeIdx];
  if(!p||!p.holdings)return false;
  const h=p.holdings[symbol];
  return !!(h&&h.qty>0);
}
function renderTicker(){
  const tc=state.stocks.map(s=>`
    <span class="ticker-item">
      <span class="muted" style="${isOwned(s.symbol)?'color:var(--accent);font-weight:600;':''}">${s.symbol}</span>
      ${(s.price||0).toFixed(2)}
      <span class="${(s.change||0)>=0?'up':'down'}">${(s.change||0)>=0?'▲':'▼'}${Math.abs(s.change||0)}%</span>
    </span>`).join('');
  const el=document.getElementById('ticker-target');
  if(el)el.innerHTML=tc+tc;
}

function renderMarketPage(){
  // Header metrics
  const rel=(state.market.fmi||100)-100;
  const fmiEl=document.getElementById('fmi-val');
  if(fmiEl){fmiEl.innerText=(rel>=0?'+':'')+rel.toFixed(2);fmiEl.className='metric-val '+(rel>=0?'up':'down');}
  const diff=state.market.fmi-state.market.lastFmi;
  const pct=state.market.lastFmi?(diff/state.market.lastFmi)*100:0;
  const fmiC=document.getElementById('fmi-change-val');
  if(fmiC)fmiC.innerText=`${pct>=0?'+':''}${pct.toFixed(2)}% this tick`;

  const total=state.stocks.reduce((a,s)=>a+(s.marketCap||0),0);
  const mcapEl=document.getElementById('mcap-val');
  if(mcapEl){
    if(total>=1000000)mcapEl.innerText=(total/1000000).toFixed(1)+'M';
    else mcapEl.innerText=(total/1000).toFixed(0)+'K';
  }

  const sorted=[...state.stocks].sort((a,b)=>(b.change||0)-(a.change||0));
  const gE=document.getElementById('gainer-val'),lE=document.getElementById('loser-val');
  if(gE&&sorted.length)gE.innerText=`${sorted[0].symbol}  +${sorted[0].change||0}%`;
  if(lE&&sorted.length)lE.innerText=`${sorted[sorted.length-1].symbol}  ${sorted[sorted.length-1].change||0}%`;

  const ups=state.stocks.filter(s=>s.change>0).length, downs=state.stocks.filter(s=>s.change<0).length;
  const bE=document.getElementById('breadth-val'),bdE=document.getElementById('breadth-desc');
  if(bE)bE.innerText=`${ups}↑  ${downs}↓`;
  if(bdE)bdE.innerText=ups>downs?'Advancing':'Declining';

  // Cycle phase card (derived from FMI trend)
  const phase=state.market.phase||'expansion';
  const regime=state.market.regime||'neutral';
  const phaseColors={expansion:'var(--green)',boom:'var(--yellow)',slowdown:'var(--text-muted)',recession:'var(--red)',recovery:'var(--blue)'};
  const phaseColor=phaseColors[phase]||'var(--text)';
  const cpEl=document.getElementById('cycle-phase-val'), crEl=document.getElementById('cycle-regime-val');
  if(cpEl){cpEl.innerText=phase.charAt(0).toUpperCase()+phase.slice(1);cpEl.style.color=phaseColor;}
  const mom=Math.round(Math.abs(state.market.momentum||0));
  const regimeLabel=regime==='bull'?`▲ Bull (mom. ${mom})`:regime==='bear'?`▼ Bear (mom. ${mom})`:'→ Neutral';
  if(crEl){crEl.innerText=regimeLabel;crEl.className='metric-sub '+(regime==='bull'?'up':regime==='bear'?'down':'muted');}

  // Sort indicators
  ['rank','symbol','name','sector','price','marketCap','change'].forEach(k=>{
    const el=document.getElementById('si-'+k);
    if(el){el.innerText=currentSort.key===k?(currentSort.asc?'▲':'▼'):'';el.style.color=currentSort.key===k?'var(--accent)':'';}
  });

  // Build table
  let ds=[...state.stocks];
  if(state.activeIdx!==-1&&state.profiles[state.activeIdx]){
    const ap=state.profiles[state.activeIdx];
    ds.forEach(s=>{if(ap.holdings[s.symbol]&&ap.holdings[s.symbol].qty>0)s.pinned=true;});
  }
  ds.sort((a,b)=>{
    if(a.pinned&&!b.pinned)return -1;
    if(!a.pinned&&b.pinned)return 1;
    const m=currentSort.asc?1:-1;
    const k=currentSort.key;
    if(['price','change','rank','marketCap'].includes(k))return((a[k]||0)-(b[k]||0))*m;
    return((a[k]||'').toString()).localeCompare((b[k]||'').toString())*m;
  });

  let html='';
  ds.forEach(s=>{
    const detailOpen=openGraphs[s.symbol]?'table-row':'none';
    const rd=(s.prevRank!==undefined)?(s.prevRank-s.rank):0;
    const ri=rd>0?`<span class="up" style="font-size:0.72rem;">▲${rd}</span>`:rd<0?`<span class="down" style="font-size:0.72rem;">▼${Math.abs(rd)}</span>`:'<span class="muted" style="font-size:0.72rem;">–</span>';
    const mcK=((s.marketCap||0)/1000).toFixed(1)+'K';
    const pfr=s.price/(impliedValue(s)||s.base);
    const vTag=pfr>1.3?'<span class="valuation-tag val-ov" title="Trading well above analyst targets">▲ OV</span>':pfr<0.75?'<span class="valuation-tag val-uv" title="Trading well below analyst targets">▼ UV</span>':'';
    const off=combinedOffset(s);
    const adjTag=Math.abs(off)>=0.02?`<span class="${off>0?'up':'down'}" style="font-size:0.75rem;margin-left:4px;" title="There's active chatter around this stock — check its detail panel">${off>0?'●':'●'}</span>`:'';
    const isOpen=openGraphs[s.symbol];
    const chevron=isOpen?'▲':'▼';
    html+=`
      <tr style="cursor:pointer;" onclick="toggleStockDetail('${s.symbol}')">
        <td onclick="event.stopPropagation();togglePin('${s.symbol}')" style="text-align:center;cursor:pointer;user-select:none;opacity:${s.pinned?1:0.22};font-size:1rem;">${s.pinned?'📌':'📍'}</td>
        <td><span class="muted" style="font-size:0.78rem;">#${s.rank!==undefined?s.rank+1:'—'}</span> ${ri}</td>
        <td><strong style="${isOwned(s.symbol)?'color:var(--accent);':''}">${s.symbol}</strong></td>
        <td class="muted" style="font-size:0.87rem;">${s.name}</td>
        <td><span class="badge badge-sector" style="font-size:0.68rem;">${s.sector.split(' ')[0]}</span></td>
        <td><strong>${(s.price||0).toFixed(2)}</strong> <span class="muted" style="font-size:0.78rem;">shards</span> ${vTag}${adjTag}</td>
        <td class="muted" style="font-size:0.83rem;">${mcK}</td>
        <td class="${(s.change||0)>=0?'up':'down'}" style="font-weight:600;">${(s.change||0)>=0?'+':''}${s.change||0}%</td>
        <td style="text-align:right;color:var(--text-muted);font-size:0.75rem;" onclick="event.stopPropagation();">
          <button onclick="setTradeAssetTarget('${s.symbol}')" style="padding:3px 7px;font-size:0.75rem; margin-right:4px;">Trade</button>
          <span id="chev-${s.symbol}" style="cursor:pointer;opacity:0.5;" onclick="toggleStockDetail('${s.symbol}')">${chevron}</span>
        </td>
      </tr>
      <tr id="chart-row-${s.symbol}" class="detail-row" style="display:${detailOpen};">
        <td colspan="9">
          <div class="detail-inner" id="detail-inner-${s.symbol}"></div>
        </td>
      </tr>`;
  });
  const tb=document.getElementById('market-body');
  if(tb)tb.innerHTML=html;

  // Restore any open detail panels after re-render
  Object.keys(openGraphs).forEach(sym=>{
    if(openGraphs[sym]) setTimeout(()=>buildInlineDetail(sym),10);
  });

  // Profile select
  const sel=document.getElementById('profile-select');
  if(sel)sel.innerHTML='<option value="-1">-- Select Account --</option>'+(state.profiles||[]).map((p,i)=>`<option value="${i}" ${i==state.activeIdx?'selected':''}>${p.name}</option>`).join('');

  const ta=document.getElementById('trade-asset');
  if(ta){
    const prevTa=ta.value;
    ta.innerHTML=state.stocks.map(s=>`<option value="${s.symbol}">${s.symbol} – ${s.name}</option>`).join('');
    if(prevTa && ta.querySelector(`option[value="${prevTa}"]`)) ta.value=prevTa;
  }

  renderActiveProfile();
}

function renderEconomyPage(){
  const e=state.economy;
  const indicators=[
    {key:'growth',       label:'Economic Growth',    desc:'Expansion vs contraction across the realm'},
    {key:'inflation',    label:'Inflation',           desc:'Rate of price increase across goods & services'},
    {key:'interestRates',label:'Interest Rates',      desc:'Cost of borrowing at guild banks'},
    {key:'globalTrade',  label:'Global Trade',        desc:'Volume of commerce flowing across trade routes'},
    {key:'stability',    label:'Political Stability', desc:'Confidence in city governance and law'}
  ];
  const indEl=document.getElementById('econ-indicators');
  if(indEl){
    indEl.innerHTML=indicators.map(({key,label,desc})=>{
      const v=e[key]||0;
      const color=econGaugeColor(key,v);
      const status=econStatus(key,v);
      let pct=key==='growth'?((v+0.5)*100):key==='inflation'?Math.min(100,v/0.08*100):key==='interestRates'?Math.min(100,v/0.12*100):(v*100);
      return `<div class="econ-indicator">
        <div class="ei-label">${label}</div>
        <div class="ei-val" style="color:${color};">${econDisplayVal(key,v)}</div>
        <div class="ei-desc">${status}</div>
        <div class="gauge-bar"><div class="gauge-fill" style="width:${pct.toFixed(0)}%;background:${color};"></div></div>
      </div>`;
    }).join('');
  }

  // Main news feed — all dispatch types
  const nfEl=document.getElementById('news-feed');
  if(nfEl){
    const all=state.news.slice(0,50);
    nfEl.innerHTML=all.length?all.map(renderNewsItem).join(''):'<p class="muted" style="font-size:0.84rem; padding:12px 0;">No dispatches yet. The market is quiet.</p>';
  }

  // Analyst reports feed
  const afEl=document.getElementById('analyst-feed');
  if(afEl){
    const items=(state.analysts||[]).slice(0,20).map(a=>{
      const colon=a.headline.indexOf(':');
      const srcLabel=colon>0?a.headline.substring(0,colon).trim():'Analyst';
      const bodyText=colon>0?a.headline.substring(colon+1).trim():a.headline;
      const color=SOURCE_COLORS[srcLabel]||'var(--purple)';
      return `<div class="news-item"><div class="news-source" style="color:${color};display:flex;align-items:center;gap:5px;"><span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${color};flex-shrink:0;"></span>${srcLabel}</div><div class="news-headline">${bodyText}</div><div class="news-time">${a.time||''}</div></div>`;
    }).join('');
    afEl.innerHTML=items||'<p class="muted" style="font-size:0.84rem;">No analyst reports yet.</p>';
  }

  // Sector conditions sidebar
  const scEl=document.getElementById('sector-conditions');
  if(scEl){
    scEl.innerHTML=SECTORS.map(sec=>{
      const sd=state.sectors[sec]||{};
      const conf=sd.confidence||0.5;
      const interest=sd.interest||0.5;
      const color=conf>0.6&&interest>0.6?'var(--green)':conf<0.4||interest<0.4?'var(--red)':'var(--text-muted)';
      const status=conf>0.6&&interest>0.6?'↑ Favorable':conf<0.4||interest<0.4?'↓ Pressured':'→ Neutral';
      return `<div style="display:flex;justify-content:space-between;align-items:center;padding:4px 0;border-bottom:1px solid var(--border);">
        <span style="font-size:0.8rem;">${sec}</span>
        <span style="color:${color};font-size:0.78rem;font-weight:600;">${status}</span>
      </div>`;
    }).join('');
  }
}

function renderNewsPage(){ renderEconomyPage(); } // News is now merged into Intelligence


const SOURCE_COLORS = {
  'The Waterdeep Ledger':          '#d4af37', // gold
  'The Dock Ward Gazette':         '#38bdf8', // cyan
  'The Guild Chronicle':           '#a3e635', // yellow-green
  'The City Financial Record':     '#fb923c', // orange
  'The Merchant\'s Bulletin':     '#34d399', // emerald
  'The North Ward Review':         '#e879f9', // magenta
  'The Civic Report':              '#5eead4', // teal
  'The Investor\'s Herald':       '#60a5fa', // blue
  'The Trade & Commerce Review':   '#f9a8d4', // pink/rose
  'Blackstaff Capital Research':   '#a78bfa', // purple
  'Open Lord Analytics':           '#fb7185', // rose-red
  'Deepwater Market Intelligence': '#818cf8', // indigo
  'The Arcane Observer':           '#c084fc',
  "The Adventurers' Post":       '#f59e0b',
};
function newsSourceColor(n){
  if(n.type==='event'||n.type==='lifecycle') return 'var(--dm-accent)';
  if(n.type==='dm') return 'var(--purple)';
  // Try to extract source name from headline (format "Source: headline")
  const colon=n.headline.indexOf(':');
  if(colon>0){
    const src=n.headline.substring(0,colon).trim();
    if(SOURCE_COLORS[src]) return SOURCE_COLORS[src];
  }
  if(n.type==='sector') return 'var(--blue)';
  if(n.type==='company') return 'var(--accent)';
  return 'var(--text-muted)';
}
function renderNewsItem(n){
  const color=newsSourceColor(n);
  // Split source from headline text for display
  const colon=n.headline.indexOf(':');
  let srcLabel=n.src||'Market', bodyText=n.headline;
  if(colon>0&&!n.headline.startsWith('⚡')){
    srcLabel=n.headline.substring(0,colon).trim();
    bodyText=n.headline.substring(colon+1).trim();
  }
  return `<div class="news-item">
    <div class="news-source" style="color:${color}; display:flex; align-items:center; gap:5px;">
      <span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:${color};flex-shrink:0;"></span>
      ${srcLabel}
    </div>
    <div class="news-headline">${bodyText}</div>
    <div class="news-time">${n.time||''}</div>
  </div>`;
}

function renderPortfolioPage(){
  renderCoinExchange();
  const sel=document.getElementById('portfolio-page-select');
  if(!sel)return;
  const prevVal=sel.value;
  sel.innerHTML='<option value="-1">-- Select Account --</option>'+(state.profiles||[]).map((p,i)=>`<option value="${i}">${p.name}</option>`).join('');
  // Restore previous selection (rebuilding innerHTML resets it otherwise)
  if(prevVal!==undefined && prevVal!==null && sel.querySelector(`option[value="${prevVal}"]`)) sel.value=prevVal;

  const ta=document.getElementById('portfolio-trade-asset');
  if(ta){
    const prevTa=ta.value;
    ta.innerHTML=state.stocks.map(s=>`<option value="${s.symbol}">${s.symbol} – ${s.name}</option>`).join('');
    if(prevTa && ta.querySelector(`option[value="${prevTa}"]`)) ta.value=prevTa;
  }

  const idx=parseInt(sel.value);
  const content=document.getElementById('portfolio-page-content');
  if(!content)return;
  if(isNaN(idx)||idx<0||!state.profiles[idx]){
    content.innerHTML='<p class="muted" style="font-size:0.85rem;">Select an account above.</p>';
    return;
  }
  const p=state.profiles[idx];
  let av=0,py=0,hHtml='';
  if(p.holdings){
    for(let k in p.holdings){
      const s=state.stocks.find(st=>st.symbol===k);
      if(!s)continue;
      const h=p.holdings[k];
      const val=h.qty*s.price;
      av+=val; py+=val-h.qty*h.avg;
      hHtml+=`<div style="display:flex;justify-content:space-between;padding:6px 0;border-bottom:1px solid var(--border);">
        <div><strong>${k}</strong><span class="muted" style="font-size:0.8rem; margin-left:6px;">${h.qty} shares</span></div>
        <div style="text-align:right;font-size:0.85rem;"><span class="muted">Avg ${h.avg.toFixed(2)}</span> → <span class="${s.price>=h.avg?'up':'down'}">${s.price.toFixed(2)}</span></div>
      </div>`;
    }
  }
  content.innerHTML=`
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:10px;margin-bottom:14px;font-size:0.87rem;">
      <div class="panel-sm"><div class="label">Cash Balance</div><strong>${(p.cash||0).toFixed(2)}</strong> shards</div>
      <div class="panel-sm"><div class="label">Net Worth</div><strong>${((p.cash||0)+av).toFixed(2)}</strong> shards</div>
      <div class="panel-sm"><div class="label">Realized P/L</div><span class="${(p.realized||0)>=0?'up':'down'}">${(p.realized||0).toFixed(2)}</span></div>
      <div class="panel-sm"><div class="label">Unrealized P/L</div><span class="${py>=0?'up':'down'}">${py.toFixed(2)}</span></div>
    </div>
    <div class="label" style="margin-bottom:6px;">Holdings</div>
    <div>${hHtml||'<p class="muted" style="font-size:0.84rem;">No positions.</p>'}</div>`;
  renderAuditLedger();
}
function renderActiveProfile(){
  const sel=document.getElementById('profile-select');
  if(!sel)return;
  const val=parseInt(sel.value);
  state.activeIdx=isNaN(val)?-1:val;
  const cont=document.getElementById('portfolio-view');
  if(!cont)return;
  if(state.activeIdx===-1||!state.profiles[state.activeIdx]){cont.style.display='none';return;}
  cont.style.display='block';
  const p=state.profiles[state.activeIdx];
  document.getElementById('active-profile-title').innerText=p.name||'—';
  document.getElementById('view-cash').innerText=(p.cash||0).toFixed(2);
  document.getElementById('view-realized').innerText=(p.realized||0).toFixed(2);
  let py=0,av=0,hHtml='';
  if(p.holdings){for(let k in p.holdings){
    const s=state.stocks.find(st=>st.symbol===k);
    if(!s)continue;
    const h=p.holdings[k];
    const val=h.qty*s.price;
    av+=val;py+=val-h.qty*h.avg;
    hHtml+=`<div class="flex-between" style="padding:3px 0;border-bottom:1px solid rgba(255,255,255,0.03);">
      <span><strong>${k}</strong> (${h.qty}) <span class="muted" style="font-size:0.74rem;">@ ${h.avg.toFixed(2)}</span></span>
      <span style="font-size:0.8rem;"><span class="${s.price>=h.avg?'up':'down'}">${s.price.toFixed(2)}</span></span>
    </div>`;
  }}
  const nwE=document.getElementById('view-net'),urE=document.getElementById('view-unrealized');
  if(nwE)nwE.innerText=((p.cash||0)+av).toFixed(2);
  if(urE){urE.innerText=py.toFixed(2);urE.className=py>=0?'up':'down';}
  const hb=document.getElementById('holdings-box');
  if(hb)hb.innerHTML=hHtml||'<div class="muted">No positions.</div>';
  const abE=document.getElementById('auto-buy-pct'),asE=document.getElementById('auto-sell-pct');
  if(abE)abE.value=p.rules&&p.rules.buyDrop?p.rules.buyDrop:'';
  if(asE)asE.value=p.rules&&p.rules.sellGain?p.rules.sellGain:'';

  // Auto-Buy Below Price rule fields
  const bbSelEl=document.getElementById('auto-buy-symbol');
  if(bbSelEl){
    const prev=bbSelEl.value;
    bbSelEl.innerHTML=state.stocks.map(s=>`<option value="${s.symbol}">${s.symbol}</option>`).join('');
    const wanted=(p.rules&&p.rules.buyBelow&&p.rules.buyBelow.symbol)||prev;
    if(wanted&&bbSelEl.querySelector(`option[value="${wanted}"]`))bbSelEl.value=wanted;
  }
  const bbPriceEl=document.getElementById('auto-buy-price'), bbQtyEl=document.getElementById('auto-buy-qty');
  if(bbPriceEl)bbPriceEl.value=(p.rules&&p.rules.buyBelow)?p.rules.buyBelow.price:'';
  if(bbQtyEl)bbQtyEl.value=(p.rules&&p.rules.buyBelow)?p.rules.buyBelow.qty:5;

  // Take-Profit projection: how much you'd realize per holding if the
  // configured gain % triggers an auto-sell right now
  const sgProjEl=document.getElementById('sell-gain-projection');
  if(sgProjEl){
    if(p.rules&&p.rules.sellGain!=null&&p.holdings){
      const lines=[];
      for(let k in p.holdings){
        const h=p.holdings[k];
        const targetPrice=h.avg*(1+p.rules.sellGain/100);
        const profit=h.qty*(targetPrice-h.avg);
        lines.push(`<div class="flex-between"><span class="muted">${k} @ ${targetPrice.toFixed(2)}</span><span class="${profit>=0?'up':'down'}">${profit>=0?'+':''}${profit.toFixed(2)}</span></div>`);
      }
      sgProjEl.innerHTML=lines.length?`<div class="muted" style="margin-top:2px;">If triggered:</div>${lines.join('')}`:'';
    } else sgProjEl.innerHTML='';
  }
  drawSparkline(p.history||[]);
}

function renderDMPage(){
  const tc=document.getElementById('dm-tick-count');
  if(tc)tc.innerText=state.tickCount||0;
  const asEl=document.getElementById('dm-auto-shocks');
  if(asEl)asEl.checked=!!(state.settings&&state.settings.autoShocks);
  const divEl=document.getElementById('dm-dividends');
  if(divEl)divEl.checked=!!(state.settings&&state.settings.dividendsEnabled);
  // Show cycle info in DM panel
  const dmCycleEl=document.getElementById('dm-cycle-info');
  if(dmCycleEl){
    const phase=state.market.phase||'expansion';
    const fmiRel=((state.market.fmi||100)-100).toFixed(2);
    dmCycleEl.innerHTML=`Phase: <strong style="color:${phase==='recession'?'var(--red)':phase==='boom'?'var(--yellow)':'var(--green)'};">${phase}</strong> &nbsp;|&nbsp; SLI: ${fmiRel>=0?'+':''}${fmiRel} &nbsp;|&nbsp; Momentum: ${(state.market.momentum||0).toFixed(1)}`;
  }
  // Sector table
  const sb=document.getElementById('dm-sector-body');
  if(sb)sb.innerHTML=SECTORS.map(sec=>{
    const sd=state.sectors[sec]||{};
    const so=(sd.offset||0);
    const conf=((sd.confidence||0.5)*100).toFixed(0);
    const int2=((sd.interest||0.5)*100).toFixed(0);
    return `<tr>
      <td style="padding:4px 8px;"><strong style="font-size:0.8rem;">${sec}</strong></td>
      <td style="padding:4px 8px;"><span class="${so>=0?'up':'down'}">${so>=0?'+':''}${(so*100).toFixed(1)}%</span> <span class="muted" style="font-size:0.72rem;">Int: ${int2}%</span></td>
      <td style="padding:4px 8px;">${conf}%</td>
      <td style="padding:4px 8px;text-align:right;">
        <button onclick="adjustSectorSentiment('${sec}',0.15)" style="padding:1px 6px;font-size:0.72rem;color:var(--green);border-color:var(--green);margin-right:3px;">↑</button>
        <button onclick="adjustSectorSentiment('${sec}',-0.15)" style="padding:1px 6px;font-size:0.72rem;color:var(--red);border-color:var(--red);">↓</button>
      </td></tr>`;
  }).join('');
  // Stock table (DM sees analyst targets, not exact implied value)
  const mb=document.getElementById('dm-market-body');
  if(mb)mb.innerHTML=state.stocks.map(s=>{
    const at=analystTargetLabel(s);
    const off=combinedOffset(s);
    const mood=off>0.05?'Bullish':off<-0.05?'Bearish':'Neutral';
    const mc=off>0.05?'var(--green)':off<-0.05?'var(--red)':'var(--text-muted)';
    return `<tr>
      <td style="padding:4px 8px;"><strong>${s.symbol}</strong> <span class="muted" style="font-size:0.72rem;">(vol ${s.vol})</span></td>
      <td style="padding:4px 8px;"><strong>${(s.price||0).toFixed(2)}</strong></td>
      <td style="padding:4px 8px;" class="muted">${at}</td>
      <td style="padding:4px 8px;color:${mc};">${mood}</td>
      <td style="padding:4px 8px;text-align:right;">
        <button onclick="adjustStockFundamentals('${s.symbol}','sentiment',0.08)" style="padding:1px 5px;font-size:0.7rem;color:var(--green);border-color:var(--green);margin-right:2px;">↑S</button>
        <button onclick="adjustStockFundamentals('${s.symbol}','sentiment',-0.08)" style="padding:1px 5px;font-size:0.7rem;color:var(--red);border-color:var(--red);margin-right:2px;">↓S</button>
        <button onclick="adjustStockFundamentals('${s.symbol}','revenue',0.15)" style="padding:1px 5px;font-size:0.7rem;color:var(--blue);border-color:var(--blue);margin-right:2px;">↑R</button>
        <button onclick="adjustStockFundamentals('${s.symbol}','revenue',-0.15)" style="padding:1px 5px;font-size:0.7rem;color:var(--purple);border-color:var(--purple);">↓R</button>
      </td></tr>`;
  }).join('');
}

function buildEventGrid(){
  const g=document.getElementById('event-grid');
  if(!g)return;
  g.innerHTML=WORLD_EVENTS.map(ev=>`<button class="event-btn" onclick="triggerWorldEvent('${ev.id}')">
    ${ev.label}<span class="ev-desc">${ev.desc}</span>
  </button>`).join('');
}

// Detail panel is now inline — see toggleStockDetail() and buildInlineDetail()

// ═══════════════════════════════════════════════════════════
//  INLINE CHART & SPARKLINE
// ═══════════════════════════════════════════════════════════
function toggleStockDetail(symbol){
  openGraphs[symbol] = !openGraphs[symbol];
  let row = document.getElementById('chart-row-'+symbol);
  const chevEl = document.getElementById('chev-'+symbol);
  if(row){
    if(openGraphs[symbol]){
      row.style.display='table-row';
      if(chevEl) chevEl.innerText='▲';
      buildInlineDetail(symbol);
    } else {
      row.style.display='none';
      if(chevEl) chevEl.innerText='▼';
    }
  } else {
    // Row not in DOM (after a full re-render); the next refreshUI will show it
    // because openGraphs[symbol] is now set. Trigger a targeted re-render of
    // just the market body without touching the timer or countdown.
    renderMarketTableOnly();
    if(openGraphs[symbol]) setTimeout(()=>buildInlineDetail(symbol), 30);
  }
}

// Re-renders only the market table body and header metrics — does NOT touch the timer
function renderMarketTableOnly(){
  renderMarketPage();
}

function buildInlineDetail(symbol){
  const s=state.stocks.find(st=>st.symbol===symbol);
  const inner=document.getElementById('detail-inner-'+symbol);
  if(!s||!inner)return;
  const ratio=s.price/(impliedValue(s)||s.base);
  const ar=analystTargetRange(s);
  let valTag;
  if(ar.noConsensus) valTag='<span style="color:var(--yellow);font-size:0.78rem;">⚠ No clear analyst consensus</span>';
  else if(ratio>1.3) valTag='<span style="color:var(--red);font-size:0.78rem;">▲ Above analyst targets</span>';
  else if(ratio<0.75) valTag='<span style="color:var(--green);font-size:0.78rem;">▼ Below analyst targets</span>';
  else valTag='<span class="muted" style="font-size:0.78rem;">Near analyst consensus</span>';
  const at=`${ar.lo.toFixed(0)} – ${ar.hi.toFixed(0)}`+(ar.noConsensus?' <span class="muted" style="font-size:0.7rem;">(no clear consensus)</span>':'');
  const h=s.history||[];
  const rangeLo=h.length?Math.min(...h):s.price, rangeHi=h.length?Math.max(...h):s.price;
  const allNews=[...(s.news||[]),...state.news.filter(n=>n.sector===s.sector||n.symbol===s.symbol)].slice(0,5);
  const chatter=buildChatter(s);
  inner.innerHTML=`
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
      <div>
        <span style="font-size:0.7rem;color:var(--text-muted);text-transform:uppercase;letter-spacing:0.05em;">${s.sector}</span>
        <div style="font-size:1.1rem;font-weight:600;margin-top:2px;">${s.symbol} <span style="font-weight:400;color:var(--text-muted);">${s.name}</span></div>
      </div>
      <div style="text-align:right;">${valTag}</div>
    </div>
    <canvas id="canvas-${symbol}" width="900" height="80" style="width:100%;border:1px solid var(--border);border-radius:4px;background:var(--bg);margin-bottom:12px;"></canvas>
    <div class="company-stat-grid">
      <div class="company-stat"><div class="s-label">Market Cap</div><div class="s-val">${((s.marketCap||0)/1000).toFixed(1)}K <span class="muted" style="font-size:0.7rem;">(${(s.sharesOutstanding||0).toLocaleString()} shares)</span></div></div>
      <div class="company-stat"><div class="s-label">Analyst Target</div><div class="s-val">${at} shards</div></div>
      <div class="company-stat"><div class="s-label">Quality Rating</div><div class="s-val" style="font-size:0.9rem;">${qualityRating(s.vol)}</div></div>
      <div class="company-stat"><div class="s-label">Market Mood</div><div class="s-val" style="font-size:0.88rem;">${moodLabel(s)}</div></div>
      <div class="company-stat"><div class="s-label">Price Momentum</div><div class="s-val" style="font-size:0.88rem;">${momentumLabel(s)}</div></div>
      <div class="company-stat"><div class="s-label">Recent Range</div><div class="s-val" style="font-size:0.88rem;">${rangeLo.toFixed(2)} – ${rangeHi.toFixed(2)}</div></div>
    </div>
    <div style="margin-top:6px; margin-bottom:14px;">
      <div class="label" style="margin-bottom:6px;">Trading Floor Chatter</div>
      <div style="display:flex; flex-direction:column; gap:6px;">
        ${chatter.map(c=>`<p class="muted" style="font-size:0.82rem; margin:0; padding:6px 10px; background:var(--bg); border:1px solid var(--border); border-radius:4px;">${c}</p>`).join('')}
      </div>
    </div>
    <div style="margin-top:10px;">
      <div class="label" style="margin-bottom:6px;">Recent Dispatches</div>
      ${allNews.length?allNews.map(renderNewsItem).join(''):'<p class="muted" style="font-size:0.82rem;">No recent dispatches.</p>'}
    </div>`;
  // Draw chart now that canvas exists
  setTimeout(()=>drawInlineDetailChart(symbol),30);
}

function drawInlineDetailChart(symbol){
  const s=state.stocks.find(st=>st.symbol===symbol);
  const canvas=document.getElementById('canvas-'+symbol);
  if(!s||!canvas)return;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,canvas.width,canvas.height);
  const pts=s.history||[];
  if(pts.length<2)return;
  const mn=Math.min(...pts)*0.97,mx=Math.max(...pts)*1.03,rng=mx-mn||1;
  // fill
  ctx.beginPath();
  pts.forEach((v,i)=>{const x=(i/(pts.length-1))*canvas.width;const y=canvas.height-((v-mn)/rng)*canvas.height;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.lineTo(canvas.width,canvas.height);ctx.lineTo(0,canvas.height);ctx.closePath();
  ctx.fillStyle='rgba(212,175,55,0.05)';ctx.fill();
  // line
  ctx.beginPath();ctx.strokeStyle='rgba(212,175,55,0.75)';ctx.lineWidth=1.5;
  pts.forEach((v,i)=>{const x=(i/(pts.length-1))*canvas.width;const y=canvas.height-((v-mn)/rng)*canvas.height;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.stroke();
}

function drawSparkline(pts){
  const canvas=document.getElementById('sparkline');
  if(!canvas||pts.length<2)return;
  const ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,canvas.width,canvas.height);
  const fl=Math.min(...pts)*0.99,ce=Math.max(...pts)*1.01,sp=ce-fl||1;
  ctx.beginPath();ctx.strokeStyle='#d4af37';ctx.lineWidth=1.5;
  pts.forEach((v,i)=>{const x=(i/(pts.length-1))*canvas.width;const y=canvas.height-((v-fl)/sp)*canvas.height;i===0?ctx.moveTo(x,y):ctx.lineTo(x,y);});
  ctx.stroke();
}

// ═══════════════════════════════════════════════════════════
//  LEDGER & HISTORY
// ═══════════════════════════════════════════════════════════
function logLedger(char,type,stock,qty,price,pl,note){
  const time=new Date().toTimeString().split(' ')[0].substring(0,5);
  if(!state.ledger)state.ledger=[];
  state.ledger.push({time,char,type,stock,qty,price:(price||0).toFixed?+(price||0).toFixed(2):price,pl:pl||0,note:note||''});
  if(state.ledger.length>120)state.ledger.shift();
}
function renderAuditLedger(){
  const body=document.getElementById('ledger-target');
  if(!body)return;
  body.innerHTML=(state.ledger||[]).slice().reverse().map(l=>{
    if(l.type==='BANKRUPTCY'||l.char==='MARKET EVENT'){
      return`<tr style="background:rgba(248,113,113,0.05);">
        <td class="muted" style="font-size:0.78rem;">${l.time}</td>
        <td colspan="3" style="color:var(--red);font-size:0.78rem;">⚡ ${l.type} — ${l.stock}</td>
        <td></td></tr>`;
    }
    return`<tr>
      <td class="muted" style="font-size:0.78rem;">${l.time}</td>
      <td style="font-size:0.8rem;">${l.char}</td>
      <td style="font-weight:600;font-size:0.78rem;">${l.type}</td>
      <td style="font-size:0.8rem;">${l.stock} ×${l.qty}</td>
      <td class="${(l.pl||0)>=0?'up':'down'}" style="font-size:0.8rem;">${(l.pl||0)!==0?(l.pl||0).toFixed(2):'—'}</td>
    </tr>`;
  }).join('');
}
function appendHistorySnapshots(){
  if(!state.profiles)return;
  state.profiles.forEach(p=>{
    let v=p.cash;
    for(let k in p.holdings){const s=state.stocks.find(st=>st.symbol===k);if(s)v+=p.holdings[k].qty*s.price;}
    if(!p.history)p.history=[];
    p.history.push(v);
    if(p.history.length>60)p.history.shift();
  });
}

// ═══════════════════════════════════════════════════════════
//  DIVIDENDS
// ═══════════════════════════════════════════════════════════
const DIVIDEND_YIELD = 0.02; // 2% of current share price, paid every 1000 ticks
function payDividendsIfDue(){
  if(!(state.settings&&state.settings.dividendsEnabled))return;
  if(state.tickCount<=0||state.tickCount%1000!==0)return;
  if(!state.profiles)return;
  state.profiles.forEach(p=>{
    if(!p.holdings)return;
    let total=0;
    for(let k in p.holdings){
      const h=p.holdings[k];
      const s=state.stocks.find(st=>st.symbol===k);
      if(!s||!h.qty)continue;
      const payout=+(s.price*h.qty*DIVIDEND_YIELD).toFixed(2);
      if(payout<=0)continue;
      p.cash=(p.cash||0)+payout;
      total+=payout;
      logLedger(p.name,'DIVIDEND',k,h.qty,s.price,payout,`${(DIVIDEND_YIELD*100).toFixed(1)}% yield`);
    }
    if(total>0){
      state.news.unshift({src:'event',headline:`💰 Quarterly dividends distributed — ${p.name} received ${total.toFixed(2)} shards`,time:newsTime(),type:'dm'});
    }
  });
}


// ═══════════════════════════════════════════════════════════
//  COIN EXCHANGE
// ═══════════════════════════════════════════════════════════
const COIN_UNITS = [
  {name:'Nib',        abbr:'cp',  nibs:1},
  {name:'Shard',      abbr:'sp',  nibs:10},
  {name:'Dragon',     abbr:'gp',  nibs:100},
  {name:'Taol',       abbr:'2gp', nibs:200, regional:true},
  {name:'Sun',        abbr:'pp',  nibs:1000},
  {name:'Harbor Moon',abbr:'5pp', nibs:5000, regional:true}
];
function renderCoinExchange(){
  const out=document.getElementById('coin-exchange-results');
  if(!out)return;
  const amtEl=document.getElementById('coin-amount'), unitEl=document.getElementById('coin-unit');
  const amt=parseFloat(amtEl?.value)||0;
  const unitNibs=parseFloat(unitEl?.value)||1;
  const totalNibs=amt*unitNibs;
  out.innerHTML=COIN_UNITS.map(u=>{
    const val=totalNibs/u.nibs;
    const disp=val>=100?val.toFixed(0):val>=1?val.toFixed(2):val.toFixed(4);
    const isInputUnit=u.nibs===unitNibs;
    return `<div class="flex-between" style="padding:3px 0; border-bottom:1px solid var(--border);${isInputUnit?'opacity:0.45;':''}">
      <span class="muted">${u.name}${u.regional?' <span style="font-size:0.68rem;">(Wtdp)</span>':''}</span>
      <strong>${disp}</strong>
    </div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════════════
//  MISC
// ═══════════════════════════════════════════════════════════
function handleSort(k){
  if(currentSort.key===k)currentSort.asc=!currentSort.asc;
  else{currentSort.key=k;currentSort.asc=true;}
  refreshUI();
}
function togglePin(symbol){const s=state.stocks.find(st=>st.symbol===symbol);if(s){s.pinned=!s.pinned;commitToStorage();refreshUI();}}
function setTradeAssetTarget(symbol){
  const el=document.getElementById('trade-asset');
  if(el)el.value=symbol;
  // Switch to market page if needed and scroll portfolio into view
  showPage('market');
}
function addMerchantProfile(){
  const input=document.getElementById('profile-input');
  const name=input.value.trim();
  if(!name)return;
  state.profiles.push({name,cash:0,holdings:{},realized:0,history:[0],rules:{buyDrop:null,sellGain:null}});
  input.value='';
  state.activeIdx=state.profiles.length-1;
  commitToStorage();refreshUI();
}
function commitRules(){
  if(state.activeIdx===-1)return;
  const p=state.profiles[state.activeIdx];
  if(!p)return;
  const buy=parseFloat(document.getElementById('auto-buy-pct').value);
  const sell=parseFloat(document.getElementById('auto-sell-pct').value);
  const bbSym=document.getElementById('auto-buy-symbol').value;
  const bbPrice=parseFloat(document.getElementById('auto-buy-price').value);
  const bbQty=parseFloat(document.getElementById('auto-buy-qty').value);
  if(!p.rules)p.rules={};
  p.rules.buyDrop=isNaN(buy)?null:buy;
  p.rules.sellGain=isNaN(sell)?null:sell;
  p.rules.buyBelow=(!isNaN(bbPrice)&&bbPrice>0)?{symbol:bbSym,price:bbPrice,qty:(isNaN(bbQty)||bbQty<=0)?5:bbQty}:null;
  commitToStorage();alert("Automation rules updated.");
}
function commitToStorage(){localStorage.setItem(STORAGE_KEY,JSON.stringify(state));}
function saveManualCheckpoint(){localStorage.setItem(SNAPSHOT_KEY,JSON.stringify(state));alert("Snapshot saved.");}
function loadManualCheckpoint(){
  const snap=localStorage.getItem(SNAPSHOT_KEY);
  if(!snap)return alert("No snapshot found.");
  if(confirm("Restore from snapshot? Current state will be overwritten.")){
    try{state=JSON.parse(snap);commitToStorage();refreshUI();}catch(e){alert("Snapshot corrupt.");}
  }
}
function exportToFile(){
  const a=document.createElement('a');
  a.href="data:text/json;charset=utf-8,"+encodeURIComponent(JSON.stringify(state));
  a.download='slgr_market_v3.json';
  document.body.appendChild(a);a.click();a.remove();
}
function importFromFile(event){
  const file=event.target.files[0];if(!file)return;
  const reader=new FileReader();
  reader.onload=function(e){
    try{
      state=JSON.parse(e.target.result);
      migrateState();
      commitToStorage();refreshUI();
      alert("Ledger imported successfully.");
    }catch(err){alert("File corrupt or unreadable.");}
  };
  reader.readAsText(file);
}
const profileSel=document.getElementById('profile-select');
if(profileSel)profileSel.addEventListener('change',renderActiveProfile);
window.onload=()=>{initExchange();};
</script>
